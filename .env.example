# Kunci API OpenAI (atau Gemini jika Anda menggunakan endpoint kompatibilitas)
OPENAI_API_KEY=your_openai_or_gemini_api_key_here

# Kredensial Database Supabase
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key_here

# Konfigurasi Akses Admin (Ganti dengan email admin Anda)
ADMIN_EMAIL=admin@djembar.ai
